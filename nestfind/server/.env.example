# ─── SERVER ───────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── MONGODB ──────────────────────────────────────────
MONGO_URI=mongodb+srv://house_rental:house_rental@cluster0.ife58q8.mongodb.net/?appName=Cluster0

# ─── JWT ──────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_long_random_jwt_secret_minimum_64_chars
JWT_REFRESH_SECRET=your_long_random_refresh_secret_minimum_64_chars
JWT_EXPIRE=15m
JWT_REFRESH_EXPIRE=7d

# ─── CLOUDINARY (image uploads) ───────────────────────
# Get from: https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ─── EMAIL (Nodemailer via Gmail) ─────────────────────
# Use Gmail App Password (not your account password)
# Enable at: https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_16_char_gmail_app_password
EMAIL_FROM=NestFind <noreply@nestfind.et>

# ─── TWILIO (SMS / OTP) ───────────────────────────────
# Get from: https://console.twilio.com
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_PHONE=+1234567890

# ─── CLIENT ───────────────────────────────────────────
CLIENT_URL=http://localhost:5173

# ─── RATE LIMITING ────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# ─── FILE UPLOAD ──────────────────────────────────────
MAX_FILE_SIZE=5242880
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/webp,application/pdf